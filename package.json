{
  "name": "@m9ter1a/mcpcheck",
  "version": "0.1.0",
  "description": "Audit any MCP server for agent ergonomics: get a 0-100 score and a list of what breaks for the agent.",
  "type": "module",
  "bin": {
    "mcpcheck": "dist/cli.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "check": "tsc --noEmit",
    "test": "npm run build && vitest run",
    "test:watch": "vitest",
    "bench": "npm --prefix bench install && node bench/run.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "audit",
    "lint",
    "agent",
    "llm",
    "ci"
  ],
  "license": "MIT",
  "author": "m9ter1a (https://github.com/m9ter1a)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/m9ter1a/mcpcheck.git"
  },
  "homepage": "https://github.com/m9ter1a/mcpcheck#readme",
  "bugs": {
    "url": "https://github.com/m9ter1a/mcpcheck/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "picocolors": "^1.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.10"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
